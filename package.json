{
  "name": "sicsemper-frontend-base",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:admin": "eslint src/application/admin src/presentation/components/features/admin src/presentation/stores/admin*.ts src/presentation/stores/admin-*.ts",
    "lint:participant": "eslint src/application/participant src/presentation/components/features/participant src/presentation/stores/participant*.ts src/presentation/stores/participant-*.ts",
    "lint:judge": "eslint src/application/judge src/presentation/components/features/judge src/presentation/stores/judge*.ts src/presentation/stores/judge-*.ts",
    "test": "vitest run",
    "test:admin": "vitest run src/application/admin src/presentation/components/features/admin",
    "test:participant": "vitest run src/presentation/components/features/participant",
    "test:judge": "vitest run src/presentation/components/features/judge",
    "openapi:types": "openapi-typescript ../SicSemper_Backend/openapi/sicsemper.openapi.json -o src/infrastructure/api/generated/backend-api.types.ts",
    "openapi:sync": "pnpm --dir ../SicSemper_Backend openapi:generate && pnpm openapi:types",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "tailwind-merge": "^3.4.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.0.1",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
